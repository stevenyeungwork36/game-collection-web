# Copy this file to .env and fill in values. Do not commit .env.
# See README or DEPLOY.md for where to set these (e.g. Netlify / Render dashboard).

# -----------------------------------------------------------------------------
# Backend (Node / Express)
# -----------------------------------------------------------------------------

# Port the server listens on. Render/similar set PORT automatically.
PORT=3001

# Set to production when deployed.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Frontend (Vite) – build-time only; used when frontend is on a different host
# -----------------------------------------------------------------------------

# Backend API base URL when frontend is served elsewhere (e.g. Netlify).
# Leave empty when frontend and backend are same origin (e.g. Render serving both).
# Example for Netlify + Render: https://your-app.onrender.com
VITE_API_BASE_URL=
